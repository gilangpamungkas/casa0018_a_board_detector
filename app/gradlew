#!/usr/bin/env sh
GRADLE_OPTS="${GRADLE_OPTS:-} -Dfile.encoding=UTF-8"
APP_HOME=`pwd -P`
CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

if [ -f "$CLASSPATH" ]; then
    exec "$JAVACMD" $JAVA_OPTS $GRADLE_OPTS \
        -classpath "$CLASSPATH" \
        org.gradle.wrapper.GradleWrapperMain "$@"
fi

# Fallback: use system gradle
exec gradle "$@"
